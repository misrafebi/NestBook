                                    <label for="productPhoto">Photo</label>
                                    <div class="image-preview">
                                        <img src="<%= product.productImage[0] || 'https://via.placeholder.com/100x100' %>" alt="Product Image">
                                    </div>
                                    <input type="file" id="productPhoto" style="display: none;">
                                    <button type="button" class="btn btn-secondary">Browse</button>
                                </div> -->
