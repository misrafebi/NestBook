<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BookNest Admin Dashboard</title>
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
  <style>
    /* Custom CSS for styling */
    body {
      background-color: #f8f9fa;
    }

    

    .content {
      margin-left: 250px;
      /* Adjust for sidebar width */
      padding: 20px;
    }

    .card {
      margin-bottom: 20px;
    }
  </style>
</head>

<body>

  <div class="container-fluid">
    <div class="row">
      <%- include('../partials/admin/sidebar') %>


      <div class="col-md-9 content">
        <h4>Admin - Dashboard</h4>

        <div class="row">
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">Profit & Expenses</div>
              <div class="card-body">
                <canvas id="profitChart"></canvas>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">Product Sale</div>
              <div class="card-body">
                <canvas id="productSaleChart"></canvas>
              </div>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">This Week</div>
              <div class="card-body">
                <canvas id="thisWeekChart"></canvas>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">Recent Orders</div>
              <div class="card-body">
                <table class="table">
                  <thead>
                    <tr>
                      <th>Book Name</th>
                      <th>Date</th>
                      <th>Rate</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Elon Musk</td>
                      <td>12-12-2024</td>
                      <td>₹500</td>
                    </tr>
                    <tr>
                      <td>The Little Prince</td>
                      <td>11-12-2024</td>
                      <td>₹200</td>
                    </tr>
                    <tr>
                      <td>The Da Vinci Code</td>
                      <td>10-12-2024</td>
                      <td>₹348</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    // Chart.js configuration here (replace with your actual data)
  </script>

</body>

</html>