                    <!--------------------------->
                    <script>
                        $(document).ready(function () {
                            // Handle Edit Button Click
                            $('.edit-btn').on('click', function () {
                                // Get existing data from the button's data attributes
                                const name = $(this).data('name');
                                const email = $(this).data('email');

                                // Populate the modal fields with the existing data
                                $('#editCustomerModal #customerName').val(name);
                                $('#editCustomerModal #customerEmail').val(email);
                                $('#editCustomerModal #customerPassword').val(''); // Password is optional, clear for security reasons

                                // Show the modal
                                $('#editCustomerModal').modal('show');
                            });

                            // Handle Save Changes Button
                            $('#saveChanges').on('click', function () {
                                const updatedName = $('#editCustomerModal #customerName').val();
                                const updatedEmail = $('#editCustomerModal #customerEmail').val();
                                const updatedPassword = $('#editCustomerModal #customerPassword').val();

                                // Log updated values (you can replace this with an AJAX call to save the data to the server)
                                console.log({
                                    name: updatedName,
                                    email: updatedEmail,
                                    password: updatedPassword
                                });

                                // Close the modal
                                $('#editCustomerModal').modal('hide');
                            });
                        });
                    </script>


                    <!------------------------->
                    <!--PAGINATION-->
                    <%- include('../partials/admin/pagination') %>
                        <!------------------------->

                </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // JavaScript for sort dropdown
        $(document).ready(function () {
            $('.dropdown-toggle').on('click', function () {
                $('.sort-dropdown').toggle();
            });
        });
    </script>

</body>

</html>