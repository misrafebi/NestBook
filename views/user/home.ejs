<style>
    .product-img img {
        width: 203px;
        height: 337px;
    object-fit: cover; /* Crop the image to fit while maintaining aspect ratio */
    border-radius: 5px; /* Optional: Add rounded corners */
}
/* Wishlist Icon Styling */
.wishlist-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(255, 255, 255, 0.8);
    padding: 5px;
    border-radius: 50%;
    z-index: 2;
    text-align: center;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s;
}

.wishlist-btn:hover {
    transform: scale(1.2);
    background: #ff6f61;
    color: white;
}

/* Book Title Styling */
.book-title {
    font-weight: bold;
    font-size: 1.05rem;
    margin: 10px 0;
    /* text-align: center; */
    text-transform: uppercase;
}

/* Add to Cart Button Styling */
.add-to-cart-btn {
    display: inline-block;
    padding: 8px 16px;
    background: rgb(87, 87, 87);
    color: #333;
    text-align: center;
    border: none;
    border-radius: 4px;
    font-size: 0.9rem;
    text-transform: uppercase;
    transition: background 0.3s, color 0.3s;
}

.add-to-cart-btn:hover {
    background: #686565;
    color: white;
}
#orginal-price{
    color: #9e9d9d;
}

/* Image Styling for Consistent Size */
/* .product-img img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 5px;
    position: relative;
} */

</style>

