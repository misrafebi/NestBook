


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reviews Page</title>
    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .review-section {
            margin: 20px;
        }
        .review-card {
            margin-bottom: 20px;
        }
        .reviewer-logo {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background-color: #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #555;
        }
        .rating {
            color: #ffc107;
        }
        .load-more-btn {
            display: block;
            width: 100%;
            text-align: center;
            margin-top: 20px;
        }
        .post-review-btn {
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="container review-section">
        <h2>Reviews</h2>
        <p><span class="badge badge-secondary">4.2</span> - 72 Reviews</p>
        <button class="btn btn-primary mb-3">Write Review</button>
        
        <div class=" review-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="reviewer-logo">E</div>
                    <div class="ml-3">
                        <h5 class="card-title">Emil</h5>
                        <h6 class="card-subtitle mb-2 text-muted">Today</h6>
                        <div class="rating">★★★★☆</div>
                    </div>
                </div>
                <p class="card-text">"Atomic Habits" by James Clear is a practical guide to building better habits through small, consistent changes. A must-read for personal growth!</p>
            </div>
        </div>

        <div class=" review-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="reviewer-logo">R</div>
                    <div class="ml-3">
                        <h5 class="card-title">Rahul</h5>
                        <h6 class="card-subtitle mb-2 text-muted">Yesterday</h6>
                        <div class="rating">★★★★★</div>
                    </div>
                </div>
                <p class="card-text">"Atomic Habits" is a game-changer, offering simple strategies to build good habits and break bad ones.</p>
            </div>
        </div>

        <div class=" review-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="reviewer-logo">MF</div>
                    <div class="ml-3">
                        <h5 class="card-title">Muhammed Fatih</h5>
                        <h6 class="card-subtitle mb-2 text-muted">2 days ago</h6>
                        <div class="rating">★★★★☆</div>
                    </div>
                </div>
                <p class="card-text">James Clear's insights make self-improvement feel achievable, one small step at a time.</p>
            </div>
        </div>

        <button class="btn btn-secondary load-more-btn">Load More Reviews</button>
        
        <div class="mt-4">
            <h5>Post a Review</h5>
            <form>
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" class="form-control" id="name" placeholder="Enter your name">
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" class="form-control" id="email" placeholder="Enter your email">
                </div>
                <div class="form-group">
                    <label for="review">Review</label>
                    <textarea class="form-control" id="review" rows="3" placeholder="Write your review here"></textarea>
                </div>
                <button type="submit" class="btn btn-primary post-review-btn">Post Review</button>
            </form>
        </div>
    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>
