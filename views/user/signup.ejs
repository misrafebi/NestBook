<!------- HEADER --------->
<%- include('../partials/user/header') %>
    <!------------------------>

    <!-------------->
    <!----- BODY ------->

    <div class="container">

        <div class="signup-form">
            <h2>Signup</h2>

            <div class="form-group">
                <button type="button" class="btn  btn-block google-btn"><i class="fab fa-google"></i> CONTINUE WITH
                    GOOGLE </button>
            </div>

            <p class="text-center">or</p>
            <div class="form-group">
                <div class="form-row">
                    <div class="col-md-6">
                        <input type="text" class="form-control" placeholder="First Name" id="firstName" name="firstName">
                    </div>
                    <div class="col-md-6">
                        <input type="text" class="form-control" placeholder="Last Name" id="secondName" name="secondName">
                    </div>
                </div>
            </div>

            <div class="form-group">
                <input type="email" class="form-control" placeholder="Email" id="email" name="email">
            </div>

            <div class="form-group">
                <input type="password" class="form-control" placeholder="Password" id="password" name="password">
            </div>

            <div class="form-group">
                <input type="password" class="form-control" placeholder="Confirm Password" id="confirmPassword" name="confirmPassword">
            </div>

            <button type="submit" class="btn btn-primary btn-block">SIGNUP</button>

            <p class="text-center mt-3">Already have an account? <a href="/login">Login</a></p>
        </div>
    </div>


    <!---------------------->


